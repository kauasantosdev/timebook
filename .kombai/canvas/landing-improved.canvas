display:flex;align-items:center;justify-content:center;flex-shrink:0;\" data-kid=\"89\">\n          <svg width=\"16\" height=\"16\" viewBox=\"0 0 24 24\" fill=\"none\" stroke=\"#16a34a\" stroke-width=\"2.5\" data-kid=\"90\"><path d=\"M22 11.08V12a10 10 0 1 1-5.93-9.14\" data-kid=\"91\"></path><polyline points=\"22 4 12 14.01 9 11.01\" data-kid=\"92\"></polyline></svg>\n        </div>\n        <div data-kid=\"93\">\n          <p style=\"font-size:11px;font-weight:700;color:#0f172a;\" data-kid=\"94\">Nova Reserva Confirmada</p>\n          <p style=\"font-size:10px;color:#64748b;\" data-kid=\"95\">Beatriz Costa · Hoje às 14:30</p>\n        </div>\n      </div>\n\n      \n      <div class=\"float-2\" style=\"position:absolute;bottom:60px;right:-10px;background:linear-gradient(135deg,#7c3aed,#a78bfa);border-radius:16px;padding:14px 18px;box-shadow:0 12px 32px rgba(124,58,237,0.3);color:white;z-index:10;text-align:center;min-width:120px;\" data-kid=\"96\">\n        <div style=\"font-size:26px;font-weight:800;font-family:'Space Grotesk',sans-serif;line-height:1;\" data-kid=\"97\">+90%</div>\n        <div style=\"font-size:10px;opacity:0.85;margin-top:2px;\" data-kid=\"98\">Crescimento</div>\n        <div style=\"font-size:10px;opacity:0.7;\" data-kid=\"99\">de Sessões</div>\n      </div>\n\n    </div>\n  </section>\n\n  \n  <div style=\"background:white;border-top:1px solid #f1f5f9;border-bottom:1px solid #f1f5f9;padding:16px 0;overflow:hidden;position:relative;z-index:10;margin-bottom:0;\" data-kid=\"100\">\n    <div class=\"marquee-track\" style=\"display:flex;gap:0;white-space:nowrap;\" data-kid=\"101\">\n      \n      <div style=\"display:flex;align-items:center;gap:48px;padding:0 32px;flex-shrink:0;\" data-kid=\"102\">\n        <div style=\"display:flex;align-items:center;gap:8px;\" data-kid=\"103\"><span style=\"font-size:20px;font-weight:800;font-family:'Space Grotesk',sans-serif;color:#7c3aed;\" data-kid=\"104\">1.200+</span><span style=\"font-size:13px;color:#6474